{
	"name": "obsidian-quick-tray",
	"version": "1.0.1",
	"description": "Keep Obsidian available from the Windows tray with quick notes, quick search, and configurable shortcuts.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"tray"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.17",
		"builtin-modules": "^5.0.0",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"typescript": "^5.8.3"
	}
}
